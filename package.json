{
  "name": "prompt-stability-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for stable prompt assembly, diagnostics, and the official OpenClaw adapter.",
  "license": "MIT",
  "repository": "https://github.com/tontoko/prompt-stability-kit",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/inspector packages/openclaw-context-engine",
    "check": "npm run lint && npm run build && npm run test",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo coverage",
    "format": "ultracite fix .",
    "lint": "ultracite check .",
    "openclaw:patch-core": "node scripts/apply-openclaw-core-compaction.mjs",
    "openclaw:verify-core": "node scripts/verify-openclaw-core-compaction.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^6.0.2",
    "ultracite": "^7.4.4",
    "vitest": "^3.2.4"
  }
}
